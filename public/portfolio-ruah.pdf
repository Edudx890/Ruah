-business-meeting.jpg\",{\"type\":\"url\",\"data\":\"https://hebbkx1anhila5yf.public.blob.vercel-storage.com/attachments/gen-images/public/elegant-professional-business-meeting-UzJWXa3Hw41MZVBQFEAUw108z8kbPR.jpg\"}],[\"package.json\",{\"type\":\"file\",\"data\":\"$29\"}],[\"README.md\",{\"type\":\"file\",\"data\":\"$2a\"}],[\"public/images/logo-ruah.jpeg\",{\"type\":\"url\",\"data\":\"https://hebbkx1anhila5yf.public.blob.vercel-storage.com/WhatsApp%20Image%202026-02-13%20at%2014.49.53-CDMn3u7fkMItea1WwQeyprgAWV8vJu.jpeg\"}],[\"lib/db-memoria.ts\",{\"type\":\"file\",\"data\":\"$2b\"}],[\"app/api/servicos/incrementar-acesso/route.ts\",{\"type\":\"file\",\"data\":\"import { type NextRequest, NextResponse } from \\\"next/server\\\"\\nimport * as db from \\\"@/lib/db-memoria\\\"\\n\\nexport async function POST(request: NextRequest) {\\n  try {\\n    const { id } = await request.json()\\n\\n    if (!id) {\\n      return NextResponse.json({ erro: \\\"ID do serviço é obrigatório\\\" }, { status: 400 })\\n    }\\n\\n    await db.incrementarAcessosServico(Number.parseInt(id))\\n\\n    return NextResponse.json({ sucesso: true })\\n  } catch (erro) {\\n    console.error(\\\"[v0] Erro ao incrementar acesso:\\\", erro)\\n    return NextResponse.json({ erro: \\\"Erro ao incrementar acesso\\\" }, { status: 500 })\\n  }\\n}\\n\"}],[\"app/api/auth/login/route.ts\",{\"type\":\"file\",\"data\":\"$2c\"}],[\"app/api/auth/registro/route.ts\",{\"type\":\"file\",\"data\":\"$2d\"}],[\"LEIA-ME-PREVIEW.md\",{\"type\":\"file\",\"data\":\"$2e\"}],[\"public/images/logo-ruah-transparente.jpg\",{\"type\":\"url\",\"data\":\"https://hebbkx1anhila5yf.public.blob.vercel-storage.com/attachments/gen-images/public/images/logo-ruah-transparente-DfFfMJLN7x3ZEoRZ22NIaKSNJEfHgG.jpg\"}],[\"app/globals.css\",{\"type\":\"file\",\"data\":\"$2f\"}],[\"app/api/contato/route.ts\",{\"type\":\"file\",\"data\":\"import { NextResponse } from \\\"next/server\\\"\\nimport * as db from \\\"@/lib/db-memoria\\\"\\n\\nexport async function POST(requisicao: Request) {\\n  try {\\n    const corpo = await requisicao.json()\\n    const { nome, email, telefone, mensagem } = corpo\\n\\n    // Validar entrada\\n    if (!nome || !email || !mensagem) {\\n      return NextResponse.json({ erro: \\\"Nome, email e mensagem são obrigatórios\\\" }, { status: 400 })\\n    }\\n\\n    await db.criarContato({\\n      nome,\\n      email,\\n      telefone: telefone || \\\"\\\",\\n      mensagem,\\n      usuario_id: null, // Não requer usuário logado\\n    })\\n\\n    return NextResponse.json({ mensagem: \\\"Mensagem enviada com sucesso\\\" }, { status: 200 })\\n  } catch (erro) {\\n    console.error(\\\"[v0] Erro ao processar formulário de contato:\\\", erro)\\n    return NextResponse.json({ erro: \\\"Erro ao processar solicitação\\\" }, { status: 500 })\\n  }\\n}\\n\"}],[\"components/servicos.tsx\",{\"type\":\"file\",\"data\":\"$30\"}],[\"components/contato.tsx\",{\"type\":\"file\",\"data\":\"$31\"}],[\"components/botao-whatsapp.tsx\",{\"type\":\"file\",\"data\":\"$32\"}],[\"components/cabecalho.tsx\",{\"type\":\"file\",\"data\":\"$33\"}],[\"public/images/brasilia-noturna.jpg\",{\"type\":\"url\",\"data\":\"https://hebbkx1anhila5yf.public.blob.vercel-storage.com/thumbpq_brasilia-37s5A0bswWHCzxZEdo17TbayPSYIpg.jpg\"}],[\"components/rodape.tsx\",{\"type\":\"file\",\"data\":\"$34\"}],[\"public/images/logo-ruah.png\",{\"type\":\"url\",\"data\":\"https://hebbkx1anhila5yf.public.blob.vercel-storage.com/ruah-removebg-preview-qqrh259QQ2Ufz7mn3oNhuRlhvaPZCO.png\"}],[\"public/images/consultoria-governo.jpg\",{\"type\":\"url\",\"data\":\"https://hebbkx1anhila5yf.public.blob.vercel-storage.com/attachments/gen-images/public/images/consultoria-governo-xTUHmG0zHN8G6dQp50qrUd7MjsZizV.jpg\"}],[\"components/sobre-nos.tsx\",{\"type\":\"file\",\"data\":\"$35\"}]],\"createdAt\":1772162415319,\"defaultPath\":\"/portfolio-ruah.pdf\",\"envPromise\":\"$@36\",\"expectSnowflake\":false}]\n"])</script><script>self.__next_f.push([1,"1